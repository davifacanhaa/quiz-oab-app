# Painel do Supabase → Project Settings → Data API / API Keys
# URL do projeto (ex: https://xxxxxxxx.supabase.co)
SUPABASE_URL=
# service_role key (SECRETA — só no servidor, nunca exponha no navegador)
SUPABASE_SERVICE_ROLE_KEY=

